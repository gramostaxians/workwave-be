<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Console (all logs) ─────────────────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Audit log file (every request) ────────────────────────────── -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/audit.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/audit.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Threat log file (suspicious / unauthorized activity) ─────── -->
    <appender name="THREAT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/security-threats.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/security-threats.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>90</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Named loggers ─────────────────────────────────────────────── -->
    <logger name="SECURITY_AUDIT" level="INFO" additivity="false">
        <appender-ref ref="AUDIT_FILE"/>
    </logger>

    <logger name="SECURITY_THREAT" level="WARN" additivity="false">
        <appender-ref ref="THREAT_FILE"/>
    </logger>

    <!-- ── Silence noisy frameworks ──────────────────────────────────── -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.liquibase" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="org.apache.tomcat" level="WARN"/>
    <logger name="org.apache.catalina" level="WARN"/>
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.springframework.web" level="WARN"/>

    <!-- ── Root logger (only your app logs at INFO) ──────────────────── -->
    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>

    <logger name="com.hr.workwave" level="INFO" additivity="true">
    </logger>

</configuration>

