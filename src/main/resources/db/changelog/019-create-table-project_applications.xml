<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="019.01-create-table-project_applications.xml" author="Gramos">
        <createTable tableName="project_applications">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="psp" type="varchar(300)">
                <constraints nullable="false"/>
            </column>
            <column name="project_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </createTable>


        <addForeignKeyConstraint
                baseTableName="project_applications"
                baseColumnNames="project_id"
                referencedTableName="project_applications"
                referencedColumnNames="id"
                constraintName="fk_project_project_application"/>
    </changeSet>

    <changeSet id="019.02-insert-project-application-data" author="Gramos">

        <loadUpdateData
                commentLineStartsWith="//"
                encoding="UTF-8"
                file="../../csv/project_application.csv"
                relativeToChangelogFile="true"
                tableName="project_applications"
                primaryKey="id">
            <column header="id"
                    name="id" />
            <column header="psp"
                    name="psp" />
        </loadUpdateData>

    </changeSet>

</databaseChangeLog>