<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="002-add-sequence-and-default-to-id" author="ERVIN">
        <createSequence sequenceName="user_managers_id_seq" />
        <addDefaultValue tableName="user_managers" columnName="id" defaultValueSequenceNext="user_managers_id_seq"/>
        <modifyDataType tableName="user_managers" columnName="id" newDataType="bigint"/>
    </changeSet>

</databaseChangeLog>
