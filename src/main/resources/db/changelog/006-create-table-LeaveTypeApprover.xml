<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="006-create-table-leave-type-approver" author="Ervin">

        <createTable tableName="leave_type_approver">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="leave_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="approver_user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="leave_type_approver"
                baseColumnNames="approver_user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_leave_type_approver_user"/>

    </changeSet>
</databaseChangeLog>
