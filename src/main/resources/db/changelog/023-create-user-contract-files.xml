<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="023-create-user-contract-files" author="copilot">
        <createTable tableName="user_contract_files">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_user_contract_files"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="filename" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="user_contract_files"
                baseColumnNames="user_id"
                constraintName="fk_user_contract_files_user"
                referencedTableName="users"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <createIndex indexName="idx_user_contract_files_user_id" tableName="user_contract_files">
            <column name="user_id"/>
        </createIndex>

        <createIndex indexName="idx_user_contract_files_user_id_created_at" tableName="user_contract_files">
            <column name="user_id"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>

