<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="007-create-table-Project.xml" author="Ervin">
        <createTable tableName="project">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_name" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="quarter_1" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="quarter_2" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="quarter_3" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="quarter_4" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>