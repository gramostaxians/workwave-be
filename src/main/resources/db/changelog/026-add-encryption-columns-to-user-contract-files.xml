<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="026-add-encryption-columns-to-user-contract-files" author="GRAMOS">
        <addColumn tableName="user_contract_files">
            <!-- Base64-encoded AES-256 key (32 bytes → 44 Base64 chars); nullable for legacy files -->
            <column name="encryption_key" type="varchar(64)"/>
            <!-- Base64-encoded 96-bit GCM IV (12 bytes → 16 Base64 chars); nullable for legacy files -->
            <column name="encryption_iv" type="varchar(32)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>

