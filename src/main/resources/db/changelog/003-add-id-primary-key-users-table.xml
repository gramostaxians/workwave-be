    <changeSet id="003-add-id-primary-key-users-table-drop-users-primary-key" author="ERVIN">
        <preConditions onFail="MARK_RAN">
            <primaryKeyExists tableName="users" primaryKeyName="users_pkey"/>
        </preConditions>
        <dropPrimaryKey tableName="users" constraintName="users_pkey"/>
        <addPrimaryKey columnNames="id" constraintName="users_pkey" tableName="users"/>
    </changeSet>

    <changeSet id="003-add-id-primary-key-users-table-create-id-users-table" author="ERVIN">
        <addColumn tableName="users">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="003-add-id-primary-key-users-table-add-column-id-foreign-tables" author="ERVIN">
        <addColumn tableName="leave_requests">
            <column name="user_id" type="bigint" />
        </addColumn>
        <addColumn tableName="ms_graph_tokens">
            <column name="user_id" type="bigint" />
        </addColumn>
    </changeSet>

    <changeSet id="003-add-id-primary-key-users-table-add-id-values-foreign-tables" author="ERVIN" runAlways="true">
        <sql>
            UPDATE leave_requests lr
            SET user_id = u.id
                FROM users u
            WHERE lr.employee_email = u.email;

            UPDATE ms_graph_tokens mgt
            SET user_id = u.id
                FROM users u
            WHERE mgt.user_email = u.email;
        </sql>
    </changeSet>


    <changeSet id="5" author="ervin">
        <addForeignKeyConstraint baseTableName="leave_requests" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_leave_requests_user_id"/>

        <addForeignKeyConstraint baseTableName="ms_graph_tokens" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_ms_graph_tokens_user_id"/>
    </changeSet>

</databaseChangeLog>
