<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="003-add-id-primary-key-users-table-drop-foreign-key" author="ERVIN">
        <preConditions onFail="MARK_RAN">
            <foreignKeyConstraintExists foreignKeyName="fk_employee_email" />
        </preConditions>
        <dropForeignKeyConstraint baseTableName="leave_requests" constraintName="fk_employee_email"/>
    </changeSet>

