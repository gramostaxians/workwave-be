<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="001-create-example-table" author="Ervin">
        <createTable tableName="user_managers">
            <column name="id" type="INT"  autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="manager_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>


        </createTable>

        <addForeignKeyConstraint
                baseTableName="user_managers"
                baseColumnNames="manager_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_manager_id"/>

        <addForeignKeyConstraint
                baseTableName="user_managers"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_user_id"/>

        <addUniqueConstraint tableName="user_managers" columnNames="manager_id,user_id" constraintName="uq_manager_user"/>
    </changeSet>

</databaseChangeLog>
