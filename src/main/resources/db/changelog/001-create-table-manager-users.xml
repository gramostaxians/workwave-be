<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="001-create-example-table" author="Ervin">
        <createTable tableName="user_managers">
            <column name="id" type="INT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="manager_email" type="varchar2(255)">
                <constraints nullable="false"/>
            </column>
            <column name="user_email" type="varchar2(255)">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="user_managers"
                baseColumnNames="manager_email"
                referencedTableName="users"
                referencedColumnNames="email"
                constraintName="fk_manager_email"/>

        <!-- Add foreign key constraint on user_id -->
        <addForeignKeyConstraint
                baseTableName="user_managers"
                baseColumnNames="user_email"
                referencedTableName="users"
                referencedColumnNames="email"
                constraintName="fk_user_email"/>
    </changeSet>

</databaseChangeLog>
